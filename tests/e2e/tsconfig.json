{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "declaration": false,
    "types": ["node", "@playwright/test"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"],
  "extends": "expo/tsconfig.base"
}
