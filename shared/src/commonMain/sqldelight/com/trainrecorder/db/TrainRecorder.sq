-- PR calculation helpers: get max weight for an exercise across all sessions
selectMaxWeightForExercise:
SELECT es.actual_weight, ws.record_date, ws.id
FROM exercise_set es
JOIN workout_exercise we ON es.workout_exercise_id = we.id
JOIN workout_session ws ON we.workout_session_id = ws.id
WHERE we.exercise_id = ? AND es.is_completed = 1 AND es.actual_weight > 0
ORDER BY es.actual_weight DESC, ws.record_date DESC
LIMIT 1;

-- PR calculation helpers: get max volume for an exercise across all sessions
selectMaxVolumeForExercise:
SELECT SUM(es.actual_weight * es.actual_reps), ws.record_date, ws.id
FROM exercise_set es
JOIN workout_exercise we ON es.workout_exercise_id = we.id
JOIN workout_session ws ON we.workout_session_id = ws.id
WHERE we.exercise_id = ? AND es.is_completed = 1 AND es.actual_reps IS NOT NULL
GROUP BY ws.id
ORDER BY SUM(es.actual_weight * es.actual_reps) DESC
LIMIT 1;

-- Get distinct exercise IDs that have completed sets
selectExercisesWithCompletedSets:
SELECT DISTINCT we.exercise_id
FROM exercise_set es
JOIN workout_exercise we ON es.workout_exercise_id = we.id
WHERE es.is_completed = 1;

-- ============================================================
