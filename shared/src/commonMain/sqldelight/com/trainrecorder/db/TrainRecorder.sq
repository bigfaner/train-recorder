selectWeightSuggestionByExerciseId:
SELECT * FROM weight_suggestion WHERE exercise_id = ?;

insertWeightSuggestion:
INSERT INTO weight_suggestion(id, exercise_id, suggested_weight, based_on_session_id, consecutive_completions, consecutive_failures, last_calculated_at, created_at, updated_at)
VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?);

updateWeightSuggestion:
UPDATE weight_suggestion
SET suggested_weight = ?, based_on_session_id = ?, consecutive_completions = ?, consecutive_failures = ?, last_calculated_at = ?, updated_at = ?
WHERE id = ?;

deleteWeightSuggestionByExerciseId:
DELETE FROM weight_suggestion WHERE exercise_id = ?;

-- Get recent workout exercises for an exercise, ordered by date desc
selectRecentWorkoutExercisesForSuggestion:
SELECT we.id, we.workout_session_id, we.exercise_id, we.order_index, we.note, we.suggested_weight, we.is_custom_weight, we.target_sets, we.target_reps, we.exercise_mode, we.exercise_status, we.created_at, we.updated_at
FROM workout_exercise we
JOIN workout_session ws ON we.workout_session_id = ws.id
WHERE we.exercise_id = ?
ORDER BY ws.record_date DESC;

-- Get recent sessions with completed sets for an exercise for weight suggestion calculation
selectRecentSetsForExercise:
SELECT es.id, es.workout_exercise_id, es.set_index, es.target_weight, es.actual_weight, es.target_reps, es.actual_reps, es.is_completed, es.rest_started_at, es.rest_duration, es.created_at, es.updated_at, ws.record_date, ws.id
FROM exercise_set es
JOIN workout_exercise we ON es.workout_exercise_id = we.id
JOIN workout_session ws ON we.workout_session_id = ws.id
WHERE we.exercise_id = ? AND es.is_completed = 1
ORDER BY ws.record_date DESC;
